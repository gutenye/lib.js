#!/usr/bin/env bun

const HELP = `
`

import { $, app } from '@gutenye/script.js'

app.help(HELP)

app.cmd('tw', '[Test] Run tests in watch mode').add(({ argv }) => {
  $`bun run test:watch ${argv}`
})

app.cmd('t', '[Test] Run tests once').add(({ argv }) => {
  $`bun run test ${argv}`
})

app.cmd('l', '[Test] Run lint').add(({ argv }) => {
  $`bun run lint ${argv}`
})

await app.run()
